# ---------------------------------------------------------------------------
# Database (PostgreSQL / Supabase)
# DATABASE_URL    -> pooled connection (PgBouncer) used by the app at runtime
# DIRECT_URL      -> direct connection used by Prisma Migrate / introspection
# ---------------------------------------------------------------------------
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stark?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/stark?schema=public"

# ---------------------------------------------------------------------------
# Auth (NextAuth / Auth.js)
# ---------------------------------------------------------------------------
NEXTAUTH_SECRET="generate-with:  openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# LLM grading provider (Automated Evaluation & Quiz Engine)
# Default to the latest Claude models for design-logic grading.
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=""
GRADING_MODEL="claude-opus-4-8"

# ---------------------------------------------------------------------------
# Supabase (optional — only if using the Supabase BaaS path)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
